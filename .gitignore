project.lock.json
project.fragment.lock.json
artifacts/

# 用户私密配置 (Secrets)
server/**/appsettings.json
!server/**/appsettings.Development.json
!server/**/appsettings.Production.json
server/**/appsettings*.user.json
.localhistory

# EF Core 迁移临时文件
*.dgml

